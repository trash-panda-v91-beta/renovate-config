{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"commitBodyTable": true,
	"dependencyDashboardTitle": "Renovate Dashboard",
	"extends": [
		":dependencyDashboard",
		":disableRateLimiting",
		":enablePreCommit",
		"config:recommended",
		"docker:enableMajor",
		"github>trash-panda-v91-beta/renovate-config:automerge",
		"github>trash-panda-v91-beta/renovate-config:custom-managers",
		"github>trash-panda-v91-beta/renovate-config:package-rules",
		"helpers:pinGitHubActionDigests"
	],
	"packageRules": [
		{
			"matchManagers": ["mise", "nix"],
			"enabled": true
		}
	],
	"minimumReleaseAge": "3 days",
	"rebaseWhen": "auto",
	"suppressNotifications": ["prEditedNotification", "prIgnoreNotification"],
	"timezone": "Europe/Prague"
}
